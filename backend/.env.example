# ==============================================================================
# CatWiki Backend Environment Configuration Template (.env.example)
# ==============================================================================
# 使用说明:
# 1. 复制此文件为 .env: `cp .env.example .env`
# 2. 根据实际部署环境修改各配置项
# 3. 生产环境建议通过环境变量注入，而非直接修改此文件
# ==============================================================================

### 1. 基础环境配置 (Basic Environment)
ENVIRONMENT=local                  # 运行环境: local, dev, prod
DEBUG=true                         # 调试模式: true, false
LOG_LEVEL=INFO                     # 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
TZ=Asia/Shanghai                   # 系统时区

# 系统身份标识
PROJECT_NAME="CatWiki API"
DESCRIPTION="CatWiki 后端服务"
VERSION="0.0.4"

# API 路由前缀
API_V1_STR="/v1"
ADMIN_API_V1_STR="/admin/v1"

### 2. 数据库配置 (PostgreSQL / PGVector)
POSTGRES_SERVER=localhost          # Local 填 localhost, Docker 填 postgres
POSTGRES_PORT=5432
POSTGRES_DB=catwiki
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres         # 🔒 生产环境务必修改！
DB_ECHO=false                      # 是否输出 SQL 执行记录

# 连接池调优
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

### 3. 安全与访问控制 (Security & CORS)
SECRET_KEY=your-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 令牌有效期 (分钟)

# CORS 允许的域名 (用逗号分隔)
BACKEND_CORS_ORIGINS=http://localhost:8001,http://localhost:8002

### 4. 对象存储配置 (RustFS / S3 Compatible)
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin      # 🔒 生产环境务必修改！
RUSTFS_BUCKET_NAME=catwiki
RUSTFS_USE_SSL=false
RUSTFS_REGION=us-east-1

# 对象存储初始化专有
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin

# 外部可读访问链接
RUSTFS_PUBLIC_URL=http://localhost:9000
RUSTFS_PUBLIC_BUCKET=true

### 5. AI 模型服务配置 (OpenAI Compatible)
# 首次启动会自动同步进数据库配置中。

# 5.1 Chat 对话
AI_CHAT_API_KEY=sk-xxxx
AI_CHAT_API_BASE=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o

# 5.2 Embedding 向量化
AI_EMBEDDING_API_KEY=sk-xxxx
AI_EMBEDDING_API_BASE=https://api.openai.com/v1
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSION=1536

# 5.3 Reranker 重排序
AI_RERANK_API_KEY=sk-xxxx
AI_RERANK_API_BASE=https://api.rerank.com/v1
AI_RERANK_MODEL=bge-reranker-v2-m3

### 6. RAG 检索与智能 Agent 调优
RAG_RECALL_K=50                    # 向量召回数量
RAG_RECALL_THRESHOLD=0.3           # 相似度阈值
RAG_ENABLE_RERANK=true             # 是否启用重排
RAG_RERANK_TOP_K=5                 # 最终给 AI 的结果数

# Agent 行为控制
AGENT_MAX_ITERATIONS=5             # ReAct 最大迭代次数
AGENT_MAX_CONSECUTIVE_EMPTY=2      # 连续空回复终止阈值

### 7. 文档解析引擎配置 (DocProcessor)
MINERU_ENABLED=true
MINERU_BASE_URL=http://localhost:8888
DOCLING_ENABLED=true
DOCLING_BASE_URL=http://localhost:8000
PADDLEOCR_ENABLED=false
PADDLEOCR_BASE_URL=http://localhost:8080

### 8. 配置覆盖控制
FORCE_UPDATE_AI_CONFIG=false      # 重启时是否用环境变量强制覆盖数据库 AI 配置
FORCE_UPDATE_DOC_PROCESSOR=false  # 重启时是否用环境变量强制覆盖数据库解析器配置
