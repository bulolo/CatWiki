# ==============================================================================
# CatWiki Backend Environment Configuration Template (.env.example)
# ==============================================================================
# 使用说明：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 按部署环境修改各项，🔒 标记的项必须修改
#   3. 生产环境建议通过容器/CI 注入而非直接保存敏感值
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. 基础环境 (Basic Environment)
# ------------------------------------------------------------------------------
ENVIRONMENT=prod                    # 运行环境: local | dev | prod
DEBUG=false                         # 调试模式: true | false
LOG_LEVEL=INFO                      # 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
TZ=Asia/Shanghai                    # 系统时区

# 版本与授权

# API 路由前缀
API_V1_STR="/v1"
ADMIN_API_V1_STR="/admin/v1"


# ------------------------------------------------------------------------------
# 2. 数据库 (PostgreSQL + PGVector)
# ------------------------------------------------------------------------------
POSTGRES_SERVER=postgres            # Local 填 localhost, Docker 填 postgres
POSTGRES_PORT=5432
POSTGRES_DB=catwiki
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres          # 🔒 生产环境务必修改
DB_ECHO=false                       # 是否输出 SQL 执行记录

# 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600


# ------------------------------------------------------------------------------
# 3. 向量存储引擎 (Vector Store Engine)
# ------------------------------------------------------------------------------
# 引擎选择: postgres | elasticsearch
#   - postgres:      默认，使用 PGVector，无需额外服务
#   - elasticsearch: 启用 ES 混合检索 (需先启动 ES 服务)
#     docker compose -f docker-compose.dev.yml --profile es up
VECTOR_STORE_TYPE=postgres

# Elasticsearch 连接 (VECTOR_STORE_TYPE=elasticsearch 时取消注释)
# ES_URL=http://elasticsearch:9200    # 容器内用服务名, 本地调试用 http://localhost:9200

# ES 认证 (三选一, 开发环境 xpack.security.enabled=false 时可全部留空)
# ES_API_KEY=                         # 优先级最高
# ES_USERNAME=                        # Basic Auth 用户名
# ES_PASSWORD=                        # Basic Auth 密码

# ES TLS (生产 HTTPS 时配置)
# ES_CA_CERTS=/path/to/ca.crt
# ES_VERIFY_CERTS=true


# ------------------------------------------------------------------------------
# 4. Redis 缓存 (Redis Cache)
# ------------------------------------------------------------------------------
REDIS_ENABLED=true                  # 关闭则回退到内存缓存
REDIS_URL=redis://redis:6379/0      # 容器内 redis:6379, 本地 localhost:6379
REDIS_PREFIX=catwiki:
CACHE_DEFAULT_TTL=300               # 默认缓存秒数


# ------------------------------------------------------------------------------
# 5. 安全 & CORS (Security & CORS)
# ------------------------------------------------------------------------------
# 🔒 生产环境必须改成强密钥 (生成: openssl rand -hex 32)
SECRET_KEY=your-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # JWT 有效期 (分钟，10080=7天)

# CORS 允许的域名 (逗号分隔)
BACKEND_CORS_ORIGINS=http://localhost:8001,http://localhost:8002


# ------------------------------------------------------------------------------
# 6. 对象存储 (RustFS / S3 Compatible)
# ------------------------------------------------------------------------------
RUSTFS_ENDPOINT=rustfs:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin       # 🔒 生产环境务必修改
RUSTFS_BUCKET_NAME=catwiki
RUSTFS_USE_SSL=false
RUSTFS_REGION=us-east-1

# 初始化专用 (仅 scripts/init_rustfs.py 首次启动建 bucket 时读取，与上面运行时凭据不同)
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin    # 🔒 生产环境务必修改

# 外部可读访问链接
RUSTFS_PUBLIC_URL=http://localhost:9000
RUSTFS_PUBLIC_BUCKET=true


# ------------------------------------------------------------------------------
# 7. AI 模型服务 (OpenAI Compatible)
# ------------------------------------------------------------------------------
# 首次启动会自动同步进数据库的 AI 配置中，后续可在 UI 修改。

# 7.1 Chat 对话
# AI_CHAT_API_KEY=sk-xxxx
# AI_CHAT_API_BASE=https://api.openai.com/v1
# AI_CHAT_MODEL=gpt-4o
# AI_CHAT_EXTRA_BODY=                # 选填。关闭思考模式参考：
#   vLLM/SGLang (Qwen3/DeepSeek-R1/GLM-4.5):  {"chat_template_kwargs": {"enable_thinking": false}}
#   托管 API (DeepSeek/Kimi K2/豆包/GLM-4.6): {"thinking": {"type": "disabled"}}
#   腾讯云 (混元Pro/T1):                       {"enable_thinking": false}
#   全家桶 (不确定时全填，未识别参数会被忽略): {"chat_template_kwargs": {"enable_thinking": false}, "thinking": {"type": "disabled"}, "enable_thinking": false}

# 7.2 Embedding 向量化
# AI_EMBEDDING_API_KEY=sk-xxxx
# AI_EMBEDDING_API_BASE=https://api.openai.com/v1
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_EMBEDDING_DIMENSION=1536
# AI_EMBEDDING_BATCH_SIZE=10          # 单次请求最大文本块数量

# 7.3 Reranker 重排序 (是否启用见 §8 的 RAG_ENABLE_RERANK)
# AI_RERANK_API_KEY=sk-xxxx
# AI_RERANK_API_BASE=https://api.openai.com/v1
# AI_RERANK_MODEL=bge-reranker-v2-m3

# 7.4 视觉语言模型 (选填，处理图文混排时使用)
# AI_VL_API_KEY=sk-xxxx
# AI_VL_API_BASE=https://api.openai.com/v1
# AI_VL_MODEL=gpt-4o-mini


# ------------------------------------------------------------------------------
# 8. RAG 检索调优 (Retrieval)
# ------------------------------------------------------------------------------
RAG_RECALL_K=50                     # 向量召回数量
RAG_RECALL_THRESHOLD=0.3            # 相似度阈值 (仅 postgres 引擎生效; ES 用 RRF 排名分，不适用绝对阈值)
RAG_ENABLE_RERANK=true              # 是否启用重排
RAG_RERANK_TOP_K=5                  # 最终给 AI 的结果数
RAG_RECALL_MAX=100                  # 召回硬上限 (10-200)，性能保险丝，常规不调


# ------------------------------------------------------------------------------
# 9. Agent 行为调优 (Agent Behavior)
# ------------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=5              # ReAct 最大迭代次数 (1-20)
AGENT_MAX_CONSECUTIVE_EMPTY=2       # 连续空回复终止阈值 (1-10)

# 长对话累积超过此消息数时，自动让 LLM 把早期对话压缩成一段摘要作为"长期记忆"，
# 后续轮次只带"摘要 + 近期消息"喂给模型，避免 token 随轮数线性膨胀。
# 调小 = 更频繁压缩、上下文更精简但多出 LLM 调用；调大 = 保留更多原文细节但更费 token。
AGENT_SUMMARY_TRIGGER_MSG_COUNT=10  # 范围 4-50


# ------------------------------------------------------------------------------
# 10. 文件上传限制 (Upload Limits)
# ------------------------------------------------------------------------------
UPLOAD_MAX_SIZE=314572800           # 单文件最大字节数 (默认 300MB)
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,svg,pdf,doc,docx,xls,xlsx,ppt,pptx,txt,md,zip


# ------------------------------------------------------------------------------
# 11. 文档解析引擎 (DocProcessor)
# ------------------------------------------------------------------------------
# 首次启动会自动同步进数据库的解析器配置，后续可在 UI 修改。

# 11.1 MinerU
# MINERU_NAME=MinerU
# MINERU_BASE_URL=http://localhost:8888
# MINERU_API_KEY=NONE
# MINERU_ENABLED=true

# 11.2 Docling
# DOCLING_NAME=Docling
# DOCLING_BASE_URL=http://localhost:8000
# DOCLING_API_KEY=NONE
# DOCLING_ENABLED=true

# 11.3 PaddleOCR
# PADDLEOCR_NAME=PaddleOCR
# PADDLEOCR_BASE_URL=http://localhost:8080
# PADDLEOCR_API_KEY=NONE
# PADDLEOCR_ENABLED=false


# ------------------------------------------------------------------------------
# 12. 任务队列 & Worker (Arq + Redis)
# ------------------------------------------------------------------------------
# 队列连接复用 §4 的 REDIS_URL；以下三项控制 worker 行为
WORKER_MAX_TRIES=3                  # 任务失败重试次数
WORKER_JOB_TIMEOUT=600              # 单任务超时（秒），PDF 解析可能较慢
WORKER_MAX_JOBS=10                  # 单 worker 进程并发任务数


# ------------------------------------------------------------------------------
# 13. 配置覆盖控制 (Force Sync)
# ------------------------------------------------------------------------------
# 默认 false：仅"首次启动且 DB 中无配置"时把 §7/§11 的 env 写入 DB。
# 改为 true：每次重启都用当前 env 覆盖 DB 中的对应配置（UI 改动会被还原）。
FORCE_UPDATE_AI_CONFIG=false
FORCE_UPDATE_DOC_PROCESSOR=false
