# ==============================================================================
# CatWiki Backend Environment Configuration Template (.env.example)
# ==============================================================================
# 使用说明:
# 1. 复制此文件为 .env: `cp .env.example .env`
# 2. 根据实际部署环境修改各配置项
# 3. 生产环境建议通过环境变量注入，而非直接修改此文件
# ==============================================================================

### 1. 基础环境配置 (Basic Environment)
ENVIRONMENT=prod                  # 运行环境: local, dev, prod
DEBUG=false                         # 调试模式: true, false
LOG_LEVEL=INFO                     # 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
TZ=Asia/Shanghai                   # 系统时区

# 系统身份标识

# API 路由前缀
API_V1_STR="/v1"
ADMIN_API_V1_STR="/admin/v1"

### 2. 数据库配置 (PostgreSQL / PGVector)
POSTGRES_SERVER=postgres           # Local 填 localhost, Docker 填 postgres
POSTGRES_PORT=5432
POSTGRES_DB=catwiki
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres         # 🔒 生产环境务必修改！
DB_ECHO=false                      # 是否输出 SQL 执行记录

# 连接池调优
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

### 3. Redis 缓存配置 (Redis Cache)
REDIS_ENABLED=true                  # 是否启用 Redis (若为 false 则回退到内存缓存)
REDIS_URL=redis://redis:6379/0      # 容器内使用 redis:6379, 本地使用 localhost:6379
REDIS_PREFIX=catwiki:
CACHE_DEFAULT_TTL=300              # 默认缓存时间 (秒)

### 4. 安全与访问控制 (Security & CORS)
# 警告: 生产环境必须修改为强密钥 (建议使用: openssl rand -hex 32)
SECRET_KEY=your-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 令牌有效期 (分钟)

# CORS 允许的域名 (用逗号分隔)
BACKEND_CORS_ORIGINS=http://localhost:8001,http://localhost:8002

### 5. 对象存储配置 (RustFS / S3 Compatible)
RUSTFS_ENDPOINT=rustfs:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin      # 🔒 生产环境务必修改！
RUSTFS_BUCKET_NAME=catwiki
RUSTFS_USE_SSL=false
RUSTFS_REGION=us-east-1

# 对象存储初始化专有 (仅用于服务端首次启动创建 Bucket)
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin

# 外部可读访问链接
RUSTFS_PUBLIC_URL=http://localhost:9000
RUSTFS_PUBLIC_BUCKET=true

### 6. AI 模型服务配置 (OpenAI Compatible)
# 首次启动会自动同步进数据库配置中。

# 6.1 Chat 对话配置
# AI_CHAT_API_KEY=sk-xxxx
# AI_CHAT_API_BASE=https://api.openai.com/v1
# AI_CHAT_MODEL=gpt-4o
# AI_CHAT_EXTRA_BODY=                # 额外 JSON 配置, 如 {"enable_thinking": true}

# 6.2 Embedding 向量化配置
# AI_EMBEDDING_API_KEY=sk-xxxx
# AI_EMBEDDING_API_BASE=https://api.openai.com/v1
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_EMBEDDING_DIMENSION=1536
# AI_EMBEDDING_BATCH_SIZE=10         # 单次请求最大文本块数量

# 6.3 Reranker 重排序配置
# AI_RERANK_ENABLE=true
# AI_RERANK_API_KEY=sk-xxxx
# AI_RERANK_API_BASE=https://api.openai.com/v1
# AI_RERANK_MODEL=bge-reranker-v2-m3

### 7. RAG 检索与智能 Agent 调优
RAG_RECALL_K=50                    # 向量召回数量
RAG_RECALL_THRESHOLD=0.3           # 相似度阈值
RAG_ENABLE_RERANK=true             # 是否启用重排
RAG_RERANK_TOP_K=5                 # 最终给 AI 的结果数

# Agent 行为控制
AGENT_MAX_ITERATIONS=5             # ReAct 最大迭代次数 (1-20)
AGENT_MAX_CONSECUTIVE_EMPTY=2      # 连续空回复终止阈值 (1-10)

### 8. 文档解析引擎配置 (DocProcessor)
# MINERU_NAME=MinerU
# MINERU_BASE_URL=http://localhost:8888
# MINERU_API_KEY=NONE
# MINERU_ENABLED=true

# DOCLING_NAME=Docling
# DOCLING_BASE_URL=http://localhost:8000
# DOCLING_API_KEY=NONE
# DOCLING_ENABLED=true

# PADDLEOCR_NAME=PaddleOCR
# PADDLEOCR_BASE_URL=http://localhost:8080
# PADDLEOCR_API_KEY=NONE
# PADDLEOCR_ENABLED=false

### 9. 任务队列与 Worker 配置 (Async Tasks)
# 向量化任务队列 (基于 Redis Streams)
VECTORIZE_QUEUE_ENABLED=true
VECTORIZE_QUEUE_STREAM=catwiki:vectorize
VECTORIZE_QUEUE_GROUP=vectorize
VECTORIZE_QUEUE_CONSUMER=
VECTORIZE_MAX_RETRY=3
VECTORIZE_VISIBILITY_TIMEOUT=60

# Worker 运行模式 (多模式逗号分隔, 如: vectorize,cleanup,notify)
WORKER_MODE=vectorize,cleanup,notify

### 10. 配置覆盖控制
FORCE_UPDATE_AI_CONFIG=false      # 重启时是否用环境变量强制覆盖数据库 AI 配置
FORCE_UPDATE_DOC_PROCESSOR=false  # 重启时是否用环境变量强制覆盖数据库解析器配置
