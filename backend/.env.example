# ==============================================================================
# CatWiki 后端环境配置模板 (.env.example)
# ==============================================================================
# 使用说明:
# 1. 复制此文件为 .env: `cp .env.example .env`
# 2. 根据实际部署环境修改各配置项
# 3. 生产环境建议通过环境变量注入，而非直接修改此文件
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 基础环境配置 (Global Settings)
# ------------------------------------------------------------------------------
ENVIRONMENT=prod                  # 运行环境: local (开发), dev (测试), prod (生产)
DEBUG=false                         # 调试模式: true (启用), false (禁用)
LOG_LEVEL=INFO                     # 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL

# 系统身份标识
PROJECT_NAME="CatWiki API"         # 系统显示名称
DESCRIPTION="CatWiki 后端服务"     # 系统基础描述
VERSION="0.0.4"                    # 当前 API 版本

# API 路由前缀
API_V1_STR="/v1"                   # 客户端 API 路由基地址
ADMIN_API_V1_STR="/admin/v1"       # 管理后台 API 路由基地址


# ------------------------------------------------------------------------------
# 2. 数据库配置 (PostgreSQL / PGVector)
# ------------------------------------------------------------------------------
# 数据库主机: 本地开发填 localhost, Docker 部署请填容器名 postgres
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=catwiki
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres         # 🔒 生产环境请务必修改！
DB_ECHO=false                      # 是否输出 SQL 执行记录 (用于调试)

# 连接池调优 (针对高并发场景)
DB_POOL_SIZE=20                    # 基础连接池大小
DB_MAX_OVERFLOW=50                 # 允许的最大溢出连接数
DB_POOL_TIMEOUT=30                 # 获取连接的超时时间 (秒)
DB_POOL_RECYCLE=3600               # 连接自动回收周期 (秒)


# ------------------------------------------------------------------------------
# 3. 安全与访问控制 (Security & CORS)
# ------------------------------------------------------------------------------
# 🔒 重要: 生产环境必须修改为长随机字符串 (推荐: openssl rand -hex 32)
SECRET_KEY=your-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 登录令牌有效期 (默认 7 天)

# CORS 允许的域名 (用逗号分隔，严禁在生产环境使用 *)
# 示例: https://admin.catwiki.ai,https://demo.catwiki.ai
BACKEND_CORS_ORIGINS=http://localhost:8001,http://localhost:8002


# ------------------------------------------------------------------------------
# 4. 对象存储配置 (RustFS / S3 兼容服务)
# ------------------------------------------------------------------------------
# 基础连接
RUSTFS_ENDPOINT=rustfs:9000        # 服务访问地址
RUSTFS_ACCESS_KEY=rustfsadmin      # 访问密钥
RUSTFS_SECRET_KEY=rustfsadmin      # 🔒 生产环境务必修改！
RUSTFS_BUCKET_NAME=catwiki         # 默认存储桶名称
RUSTFS_USE_SSL=false               # 内部通信是否加密 (生产建议开启)
RUSTFS_REGION=us-east-1

# 容器初始化专有 (若无特殊需求请保持与 ACCESS_KEY 一致)
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin

# 外网预览与策略
RUSTFS_PUBLIC_URL=http://localhost:9000 # 前端访问预览图片的公网地址
RUSTFS_PUBLIC_BUCKET=true          # 是否将存储桶设为公共可读


# ------------------------------------------------------------------------------
# 5. AI 模型服务配置 (OpenAI 兼容协议)
# ------------------------------------------------------------------------------
# 注意: AI 配置首次启动会同步到数据库系统配置中。若之后在 UI 修改，此变量将失效。
# 如果需要强制用此变量覆盖数据库，请将 FORCE_UPDATE_AI_CONFIG 设为 true。

# 5.1 Chat 对话
# AI_CHAT_API_KEY=sk-your-key
# AI_CHAT_API_BASE=https://api.openai.com/v1
# AI_CHAT_MODEL=gpt-4o

# 5.2 Embedding 向量化
# AI_EMBEDDING_API_KEY=sk-your-key
# AI_EMBEDDING_API_BASE=https://api.openai.com/v1
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_EMBEDDING_DIMENSION=1536
# AI_EMBEDDING_BATCH_SIZE=10        # 批量处理上限 (OpenAI 推荐 2048, 阿里云限制 10)

# 5.3 Reranker 重排序
# AI_RERANK_API_KEY=sk-your-key
# AI_RERANK_API_BASE=https://api.openai.com/v1
# AI_RERANK_MODEL=bge-reranker-v2-m3

# 5.4 VL 视觉/多模态
# AI_VL_API_KEY=sk-your-key
# AI_VL_API_BASE=https://api.openai.com/v1
# AI_VL_MODEL=gpt-4o


# ------------------------------------------------------------------------------
# 6. RAG 检索与智能 Agent 调优
# ------------------------------------------------------------------------------
# 检索控制
# RAG_RECALL_K=50                    # Vector 检索召回的 Top-K 数量
# RAG_RECALL_MAX=100                 # 全局召回文档块上限
# RAG_RECALL_THRESHOLD=0.3           # 相似度召回阈值 (0.0-1.0)
# RAG_ENABLE_RERANK=true             # 是否启用重排序精排
# RAG_RERANK_TOP_K=5                 # 最终给到 AI 的背景段落数

# Agent 行为控制 (ReAct 模式)
# AGENT_MAX_ITERATIONS=5             # 对话 Agent 最大思考迭代次数
# AGENT_MAX_CONSECUTIVE_EMPTY=2      # 遇到连续空回复的自动终止点
# AGENT_SUMMARY_TRIGGER_MSG_COUNT=10 # 触发对话长列表自动摘要的消息数


# ------------------------------------------------------------------------------
# 7. 文档解析引擎配置 (DocProcessor)
# ------------------------------------------------------------------------------
# 各引擎的 BASE_URL 填写对应的解析服务地址

# 7.1 MinerU (深度学术/PDF 解析)
# MINERU_ENABLED=true
# MINERU_NAME=MinerU
# MINERU_BASE_URL=http://mineru-service:8888
# MINERU_API_KEY=sk-mineru-key

# 7.2 Docling (通用文档解析)
# DOCLING_ENABLED=true
# DOCLING_NAME=Docling
# DOCLING_BASE_URL=http://docling-service:8000
# DOCLING_API_KEY=sk-docling-key

# 7.3 PaddleOCR (图片/扫描件 OCR)
# PADDLEOCR_ENABLED=false
# PADDLEOCR_NAME=PaddleOCR
# PADDLEOCR_BASE_URL=http://paddleocr-service:8080
# PADDLEOCR_API_KEY=NONE


# ------------------------------------------------------------------------------
# 8. 全局限制与开关 (Limits & Flags)
# ------------------------------------------------------------------------------
# 文件上传控制
# UPLOAD_MAX_SIZE=104857600          # 单个文件上传上限 (字节，默认 100MB)
# UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,txt,md,jpg,png,zip # 允许的文件后缀

# 配置同步控制 (仅用于调试环境同步)
FORCE_UPDATE_AI_CONFIG=false       # 重启时是否用环境变量强制覆盖数据库 AI 配置
FORCE_UPDATE_DOC_PROCESSOR=false   # 重启时是否用环境变量强制覆盖数据库解析器配置
